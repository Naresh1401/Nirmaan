# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://nirmaan:nirmaan@localhost:5432/nirmaan

# ═══════════════════════════════════════════════════════════════
# AUTH & SECURITY
# ═══════════════════════════════════════════════════════════════
# Generate a secure key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ═══════════════════════════════════════════════════════════════
# REDIS (for Celery task queue)
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# CORS & FRONTEND
# ═══════════════════════════════════════════════════════════════
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
NEXT_PUBLIC_API_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════
# DEBUG MODE (enables /docs and /redoc on the API)
# ═══════════════════════════════════════════════════════════════
DEBUG=true

# ═══════════════════════════════════════════════════════════════
# TWILIO — SMS OTP Delivery (optional)
# ═══════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════
# GOOGLE MAPS (optional — delivery routing)
# ═══════════════════════════════════════════════════════════════
GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════════
# RAZORPAY — Payment Gateway (optional)
# ═══════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ═══════════════════════════════════════════════════════════════
# AWS S3 — File Storage (optional)
# ═══════════════════════════════════════════════════════════════
S3_BUCKET=nirmaan-uploads
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
